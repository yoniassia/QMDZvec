# MemClawz v5 Configuration
# Copy to .env and fill in values

# API Keys (or set via credential files)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=yoniclaw_memories

# LCM Database
LCM_DB_PATH=/home/yoniclaw/.openclaw/lcm.db
AGENTS_DIR=/home/yoniclaw/.openclaw/agents

# Watcher
SYNC_INTERVAL=1800

# API Server
MEMCLAWZ_API_PORT=3500
MEMCLAWZ_API_HOST=0.0.0.0
